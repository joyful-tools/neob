{
	"name": "@joyful.tools/neob",
	"version": "1.0.1",
	"description": "Accessible React 19 components with a bold Neo-Brutalist design system",
	"type": "module",
	"license": "MIT",
	"author": "Timo Wilhelm",
	"homepage": "https://github.com/joyful-tools/neob#readme",
	"bugs": {
		"url": "https://github.com/joyful-tools/neob/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/joyful-tools/neob.git",
		"directory": "packages/neob-ui"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		},
		"./dist/index.css": "./dist/index.css"
	},
	"files": [
		"dist",
		"README.md",
		"USAGE.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bun run typecheck && vite build && bun run package:verify",
		"package:verify": "bun scripts/verify-package.ts",
		"test:unit": "vitest run --config vitest.unit.config.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@phosphor-icons/react": "^2.1.10",
		"@use-gesture/react": "^10.3.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"motion": "^12.26.1",
		"perfect-cursors": "^1.0.5",
		"react-day-picker": "^10.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"sideEffects": [
		"**/*.css"
	]
}
