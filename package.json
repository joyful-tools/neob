{
	"name": "neob",
	"version": "1.0.0",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		},
		"./dist/index.css": "./dist/index.css"
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"build": "vite build",
		"format": "prettier --write . && eslint --fix .",
		"typecheck": "tsc --noEmit",
		"lint": "prettier --check . && eslint .",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:test": "vitest run --config vitest.config.ts",
		"storybook:test:watch": "vitest --config vitest.config.ts",
		"check": "bun run lint && bun run typecheck && bun run storybook:test",
		"storybook:deploy": "wrangler deploy",
		"prepare": "husky"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@base-ui/react": "^1.3.0",
		"@eslint/js": "^9.39.4",
		"@phosphor-icons/react": "^2.1.10",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/react-vite": "^10.4.1",
		"@storybook/test": "^8.6.15",
		"@tailwindcss/vite": "^4.1.18",
		"@vitest/browser": "^3.2.4",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-better-tailwindcss": "^4.0.0-prettier.1",
		"eslint-plugin-import-x": "^4.16.1",
		"eslint-plugin-react-compiler": "^19.1.0-rc.2",
		"eslint-plugin-react-hooks": "^7.0.0",
		"eslint-plugin-react-refresh": "^0.4.26",
		"eslint-plugin-storybook": "^10.4.1",
		"eslint-plugin-unicorn": "^62.0.0",
		"eslint-plugin-unused-imports": "^4.3.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"motion": "^12.26.1",
		"playwright": "^1.55.0",
		"prettier": "^3.7.4",
		"react": "^19.2.3",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.3",
		"react-router-dom": "^7.12.0",
		"sonner": "^2.0.7",
		"storybook": "^10.4.1",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.50.1",
		"vite": "^6.4.2",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^3.2.4",
		"wrangler": "^4.21.0"
	}
}
